<div class="cart-item" style="border:1px dashed #aaa;padding:8px;margin:4px 0">
    <table border="1" cellpadding="4">
        <tr><th>Path</th><th>Actual</th><th>Expected after editing qty</th></tr>
        <tr>
            <td>item.name</td>
            <td><span data-wire="item.name">{{ item.name }}</span></td>
            <td>{{ item.name }} (unchanged)</td>
        </tr>
        <tr>
            <td>item.price</td>
            <td><span data-wire="item.price">{{ item.price }}</span></td>
            <td>{{ item.price }} (unchanged)</td>
        </tr>
        <tr>
            <td>item.quantity</td>
            <td><input data-wire="item.quantity:value" value="{{ item.quantity }}"></td>
            <td>Whatever you type (only this row)</td>
        </tr>
    </table>
</div>
