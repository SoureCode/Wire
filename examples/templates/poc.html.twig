{% wire cascade %}
{% extends 'layout.html.twig' %}

{% block title %}Wire E2E POC{% endblock %}

{% block content %}
<h1>Wire E2E POC</h1>

<section>
    <h2>Scenario 1: Simple binding + two-way input</h2>
    <input data-wire="user.name:value" value="{{ user.name }}"> (type here)
    <button onclick="Wire.get('poc.html.twig').user.email='changed@example.com'">Change email via JS</button>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Path</th><th>Actual</th><th>Expected after typing</th></tr>
        <tr>
            <td>user.name (text)</td>
            <td><span data-wire="user.name">{{ user.name }}</span></td>
            <td>Whatever you typed</td>
        </tr>
        <tr>
            <td>user.email (text)</td>
            <td><span data-wire="user.email">{{ user.email }}</span></td>
            <td>changed@example.com (after button click)</td>
        </tr>
    </table>
</section>

<section>
    <h2>Scenario 2: Class binding + multiple references to same path</h2>
    <style>.active{background:green;color:white;padding:2px 8px}.inactive{background:red;color:white;padding:2px 8px}</style>
    <button onclick="Wire.get('poc.html.twig').user.status='active'">Set active</button>
    <button onclick="Wire.get('poc.html.twig').user.status='inactive'">Set inactive</button>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Element</th><th>Actual class</th><th>Expected after "Set inactive"</th></tr>
        <tr>
            <td>Element 1</td>
            <td><span data-wire="user.status:class">{{ user.status }}</span></td>
            <td class="inactive">inactive</td>
        </tr>
        <tr>
            <td>Element 2 (same path)</td>
            <td><span data-wire="user.status:class">{{ user.status }}</span></td>
            <td class="inactive">inactive</td>
        </tr>
    </table>
</section>

<section>
    <h2>Scenario 3: Object reference — user === cart.owner</h2>
    <input data-wire="user.name:value" value="{{ user.name }}"> (type here)
    <button onclick="Wire.get('poc.html.twig').cart.owner.name='Changed via cart'">Change via cart.owner.name</button>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Path</th><th>Actual</th><th>Expected after typing "New Name"</th></tr>
        <tr>
            <td>user.name</td>
            <td><span data-wire="user.name">{{ user.name }}</span></td>
            <td>New Name</td>
        </tr>
        <tr>
            <td>cart.owner.name</td>
            <td><span data-wire="cart.owner.name">{{ cart.owner.name }}</span></td>
            <td>New Name (same object — must follow)</td>
        </tr>
    </table>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Path</th><th>Actual</th><th>Expected after button click</th></tr>
        <tr>
            <td>user.name</td>
            <td><span data-wire="user.name">{{ user.name }}</span></td>
            <td>Changed via cart (must follow)</td>
        </tr>
        <tr>
            <td>cart.owner.name</td>
            <td><span data-wire="cart.owner.name">{{ cart.owner.name }}</span></td>
            <td>Changed via cart</td>
        </tr>
    </table>
</section>

<section>
    <h2>Scenario 4: Included template + cross-scope object reference</h2>
    {% include 'address.html.twig' with { 'address': address } %}
    <p><em>Type "Munich" in the input above (address.html.twig scope). The table below is in poc.html.twig scope — same object, so city must update here too.</em></p>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Path (poc scope)</th><th>Actual</th><th>Expected after typing "Munich"</th></tr>
        <tr>
            <td>address.street</td>
            <td><span data-wire="address.street">{{ address.street }}</span></td>
            <td>123 Main St (unchanged)</td>
        </tr>
        <tr>
            <td>address.city</td>
            <td><span data-wire="address.city">{{ address.city }}</span></td>
            <td>Munich (cross-scope update)</td>
        </tr>
        <tr>
            <td>address.zip</td>
            <td><span data-wire="address.zip">{{ address.zip }}</span></td>
            <td>10115 (unchanged)</td>
        </tr>
    </table>
</section>

<section>
    <h2>Scenario 5: Loop (cart items — each with own scope)</h2>
    <p><em>Each item has its own scope. Editing quantity input in one row must not affect other rows.</em></p>
    {% for item in cart.items %}
        {% include 'cart_item.html.twig' with { 'item': item } %}
    {% endfor %}
    <p>Total items: <span data-wire="cart.itemCount">{{ cart.itemCount }}</span></p>
    <button onclick="Wire.get('poc.html.twig').cart.itemCount++">Increment item count</button>
    <button onclick="alert('cart_item scopes: ' + Wire.getAll('cart_item.html.twig').length)">Wire.getAll() count</button>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Expected</th><th>Result</th></tr>
        <tr><td>Row 1: Shoes, 49.99, qty input independent</td><td>See above</td></tr>
        <tr><td>Row 2: Hat, 50, qty input independent</td><td>See above</td></tr>
        <tr><td>cart.itemCount increments on button click</td><td>See counter above</td></tr>
        <tr><td>Wire.getAll() alert shows 2</td><td>Click button above</td></tr>
    </table>
</section>

<section>
    <h2>Scenario 6: Embed (summary) — cascade only, no {% wire %} in template</h2>
    {% embed 'summary.html.twig' with { 'summary': cart.summary } %}
        {% block summary_title %}Order Summary{% endblock %}
    {% endembed %}
    <button onclick="Wire.get('summary.html.twig').summary.total=199.99">Change total via JS</button>
    <p><em>cart.summary === summary (same object). Mutating via embed scope must update poc scope too.</em></p>
    <table border="1" cellpadding="6" style="margin-top:8px">
        <tr><th>Path</th><th>Actual</th><th>Expected after button click</th></tr>
        <tr>
            <td>summary.total (embed scope)</td>
            <td><em>see above</em></td>
            <td>199.99</td>
        </tr>
        <tr>
            <td>cart.summary.total (poc scope)</td>
            <td><span data-wire="cart.summary.total">{{ cart.summary.total }}</span></td>
            <td>199.99 (cross-scope update)</td>
        </tr>
    </table>
</section>

<section>
    <h2>Scenario 7: snapshot()</h2>
    <p><em>snapshot(name) deep-clones a single scope. snapshot() (no arg) dumps all scopes. Refs resolve to real values.</em></p>
    <button onclick="document.getElementById('snap-out').textContent = JSON.stringify(Wire.snapshot('poc.html.twig'), null, 2)">Snapshot poc scope</button>
    <button onclick="document.getElementById('snap-out').textContent = JSON.stringify(Wire.snapshot('summary.html.twig'), null, 2)">Snapshot summary scope</button>
    <button onclick="document.getElementById('snap-out').textContent = JSON.stringify(Wire.snapshot(), null, 2)">Snapshot all scopes</button>
    <pre id="snap-out" style="background:#f4f4f4;padding:8px;margin-top:8px;font-size:12px"></pre>
</section>

<section>
    <h2>Scenario 8: MutationObserver — dynamic element registration</h2>
    <p><em>Click "Inject" to add a data-wire="user.name" span dynamically. Wire must register it without re-parsing. Then type in the Scenario 1 input — the injected span must update too.</em></p>
    <div id="mutation-target" style="border:1px dashed #aaa;padding:8px;min-height:24px;margin-bottom:8px">(injected elements appear here)</div>
    <button onclick="const el=document.createElement('span');el.setAttribute('data-wire','user.name');el.textContent=Wire.get('poc.html.twig').user.name;document.getElementById('mutation-target').appendChild(el)">Inject data-wire span</button>
    <p><em>After injecting, change user.name via the Scenario 1 input — all injected spans must follow.</em></p>
</section>
{% endblock %}
