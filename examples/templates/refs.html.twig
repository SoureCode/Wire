{% extends 'layout.html.twig' %}

{% block title %}References{% endblock %}

{% block content %}
{# --- Scenario A: arrays (copies) --- #}
{# user and cart.owner are independent copies — changing one does NOT affect the other #}
<h2>Array (copy)</h2>
<span data-wire="user.name">{{ user.name }}</span>
<span data-wire="cart.owner.name">{{ cart.owner.name }}</span>
<input data-wire="user.name:value" value="{{ user.name }}">

{# --- Scenario B: objects (same reference) --- #}
{# person and order.owner are the same object — changing one SHOULD affect the other #}
<h2>Object (reference)</h2>
<span data-wire="person.name">{{ person.name }}</span>
<span data-wire="order.owner.name">{{ order.owner.name }}</span>
<input data-wire="person.name:value" value="{{ person.name }}">
{% endblock %}
